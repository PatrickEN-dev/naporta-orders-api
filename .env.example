# Runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://naporta:naporta@localhost:5432/naporta?schema=public

# Auth — generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-with-at-least-32-characters-please
JWT_REFRESH_SECRET=change-me-with-at-least-32-characters-please-too
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
TRUST_PROXY=0

# Health
MEMORY_HEAP_LIMIT_MB=256
DB_PING_TIMEOUT_MS=2000
